SCOUT_QUEUE_CONNECTION=redis
SCOUT_QUEUE=scout
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey
MEILISEARCH_NO_ANALYTICS=false

